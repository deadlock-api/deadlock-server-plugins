# Steam credentials (required for downloading Deadlock server files)
STEAM_LOGIN=
STEAM_PASSWORD=

# Server configuration
SERVER_PORT=27015
SERVER_MAP=dl_midtown
SERVER_PASSWORD=
RCON_PASSWORD=

# Runtime versions
PROTON_VERSION=GE-Proton10-33
DOTNET_VERSION=10.0.0

# Extra arguments passed to deadworks.exe (appended after defaults)
DEADWORKS_ARGS=

# StatusPoker plugin (DEADWORKS_ENV_ prefix is stripped at runtime)
DEADWORKS_ENV_API_BASE=https://api.deadlock-api.com
DEADWORKS_ENV_SECRET=
DEADWORKS_ENV_GAME_MODE=
DEADWORKS_ENV_REGION=
DEADWORKS_ENV_IP=
DEADWORKS_ENV_PORT=27015
DEADWORKS_ENV_INTERVAL_SECONDS=30

# HLTV / Source TV
TV_ENABLE=0
TV_DELAY=0
TV_BROADCAST_URL=http://hltv-relay:3000/publish
TV_BROADCAST_AUTH=deadlock-relay
